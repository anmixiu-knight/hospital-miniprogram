/* pages/login/login.wxss */
.login-container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background-color: #e8f5e9; /* 稍微深一点的背景 */
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.icon-circle {
  width: 140rpx;
  height: 140rpx;
  background-color: #2e7d32; /* 医疗深绿 */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(46, 125, 50, 0.3);
  margin-bottom: 20rpx;
}

.icon-text {
  color: white;
  font-size: 80rpx;
  font-weight: bold;
}

.app-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1b5e20;
}

.login-form {
  width: 100%;
  background-color: white;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05);
}

.input-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  margin-bottom: 15rpx;
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  border-bottom: 2px solid #e0e0e0;
  font-size: 30rpx;
  color: #333;
}

.input:focus {
  border-bottom-color: #2e7d32;
}

.btn-login {
  background-color: #2e7d32;
  color: white;
  font-weight: bold;
  margin-top: 60rpx;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 12rpx rgba(46, 125, 50, 0.4);
}

.btn-login:active {
  background-color: #1b5e20;
}

.footer {
  margin-top: auto;
  color: #999;
  font-size: 24rpx;
}