/* pages/login/login.wxss */
.login-container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background-color: #e8f5e9; /* 稍微深一点的背景 */
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.icon-circle {
  width: 140rpx;
  height: 140rpx;
  background-color: #2e7d32; /* 医疗深绿 */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(46, 125, 50, 0.3);
  margin-bottom: 20rpx;
}

.icon-text {
  color: white;
  font-size: 80rpx;
  font-weight: bold;
}

.app-title {
  font-size: 44rpx; /* 加大标题 */
  font-weight: 800;
  color: #1b5e20;
  letter-spacing: 4rpx; /* 增加字间距显得更正式 */
  text-shadow: 0 4rpx 8rpx rgba(27, 94, 32, 0.15); /* 增加投影 */
}

.login-form {
  width: 100%;
  background-color: white;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.input-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  margin-bottom: 15rpx;
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  border-bottom: 2px solid #e0e0e0;
  font-size: 30rpx;
  color: #333;
}

.input:focus {
  border-bottom-color: #2e7d32;
}

.password-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.password-input-wrapper .input {
  padding-right: 50rpx;
}

.eye-toggle {
  position: absolute;
  right: 0;
  width: 60rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
}

/* 眼睛外框 (杏仁形) */
.eye-shape {
  width: 32rpx;
  height: 20rpx;
  border: 3rpx solid #999;
  border-radius: 70% 15%; /* 杏仁形状 */
  transform: rotate(45deg);
  box-sizing: border-box;
  transition: border-color 0.2s;
}

/* 瞳孔 (圆点) */
.eye-pupil {
  width: 10rpx;
  height: 10rpx;
  background-color: #999;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  transition: background-color 0.2s;
}

/* 斜线 (闭眼时的线) */
.eye-slash {
  width: 36rpx;
  height: 3rpx;
  background-color: #999;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
  opacity: 1; /* 默认显示 (闭眼) */
  transition: opacity 0.2s;
  border-radius: 2rpx;
}

/* --- 睁眼状态 (激活态) --- */
.eye-toggle.is-open .eye-slash {
  opacity: 0;
}

.eye-toggle.is-open .eye-shape {
  border-color: #2e7d32;
}

.eye-toggle.is-open .eye-pupil {
  background-color: #2e7d32;
}

.btn-login {
  background-color: #2e7d32;
  color: white;
  font-weight: bold;
  margin-top: 60rpx;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 12rpx rgba(46, 125, 50, 0.4);
}

.btn-login:active {
  background-color: #1b5e20;
}

.footer {
  margin-top: auto;
  color: #999;
  font-size: 24rpx;
}
