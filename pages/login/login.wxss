/* pages/login/login.wxss */

/* 1. 整体容器：使用柔和的渐变背景，垂直居中 */
.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center; /* 垂直居中 */
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(
    135deg,
    #e8f5e9 0%,
    #ffffff 100%
  ); /* 浅绿到白色的清新渐变 */
  box-sizing: border-box;
}

/* 2. Logo 区域：加大尺寸，增加投影 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  animation: fadeInDown 0.8s ease-out; /* 简单的入场动画 */
}

.icon-circle {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #43a047, #2e7d32); /* 图标也用渐变 */
  border-radius: 40rpx; /* 圆角矩形比纯圆更现代 */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 40rpx rgba(46, 125, 50, 0.2);
  margin-bottom: 30rpx;
  position: relative;
}

/* 装饰性光泽 */
.icon-circle::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  background: linear-gradient(rgba(255, 255, 255, 0.2), transparent);
}

.icon-text {
  color: white;
  font-size: 80rpx;
  font-weight: bold;
}

.app-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1b5e20;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 3. 登录表单卡片：悬浮感 */
.login-form {
  width: 100%;
  max-width: 600rpx;
  background-color: white;
  padding: 50rpx 40rpx;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05); /* 柔和的大投影 */
  animation: fadeInUp 0.8s ease-out 0.2s backwards; /* 延迟入场，使用backwards保留初始状态 */
}

/* 动画定义 */
@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 4. 输入框组：现代风格，背景色填充 */
.input-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  margin-bottom: 15rpx;
  font-size: 28rpx;
  color: #4caf50; /* 标签使用强调色 */
  font-weight: 600;
}

/* 通用输入框样式 */
.input {
  width: 100%;
  height: 90rpx;
  background-color: #f5f7f6; /* 浅灰背景 */
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box; /* 确保 padding 不撑大 */
  border: 2rpx solid transparent; /* 预留边框位置 */
  transition: all 0.3s;
}

.input:focus {
  background-color: #fff;
  border-color: #2e7d32; /* 聚焦时边框变绿 */
  box-shadow: 0 0 10rpx rgba(46, 125, 50, 0.1);
}

/* 密码框特殊处理 */
.password-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.password-input-wrapper .input {
  padding-right: 80rpx !important; /* 给眼睛图标留位置，强制覆盖 */
}

/* 5. 眼睛图标按钮：保持原有 QQ 风格逻辑，微调位置 */
.eye-toggle {
  position: absolute;
  right: 15rpx; /* ??????? */
  top: 50%; /* ???? */
  transform: translateY(-50%); /* ?????? */
  width: 60rpx; /* ?????? */
  height: 60rpx; /* ???????flex????????0 */
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 1000; /* ???? */
}

/* ?? Modal ?? eye-toggle ???? */
.modal-pwd-wrapper .eye-toggle {
  position: absolute;
  right: 10rpx; /* ???? */
  top: 50%;
  transform: translateY(-50%);
  z-index: 2002; /* ???????? modal-content */
}

/* QQ 风格眼睛绘制代码复用 */
.eye-shape {
  width: 32rpx;
  height: 20rpx;
  border: 3rpx solid #b0bec5; /* 颜色更淡一点适配浅色背景 */
  border-radius: 70% 15%;
  transform: rotate(45deg);
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.eye-pupil {
  width: 10rpx;
  height: 10rpx;
  background-color: #b0bec5;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  transition: background-color 0.2s;
}

.eye-slash {
  width: 36rpx;
  height: 3rpx;
  background-color: #b0bec5;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
  opacity: 1; /* 闭眼时显示斜杠 */
  transition: opacity 0.2s;
  border-radius: 2rpx;
}

/* 睁眼状态 */
.eye-toggle.is-open .eye-slash {
  opacity: 0;
}
.eye-toggle.is-open .eye-shape {
  border-color: #2e7d32;
}
.eye-toggle.is-open .eye-pupil {
  background-color: #2e7d32;
}

/* 6. 登录按钮：渐变色、大圆角 */
.btn-login {
  background: linear-gradient(90deg, #43a047, #2e7d32);
  color: white;
  font-weight: bold;
  font-size: 34rpx;
  height: 96rpx;
  display: flex; /* 确保 flex 布局使文字居中 */
  align-items: center;
  justify-content: center;
  margin-top: 60rpx;
  border-radius: 48rpx; /* 全圆角 */
  box-shadow: 0 10rpx 20rpx rgba(43, 160, 71, 0.3);
  border: none;
  transition: all 0.2s;
}

.btn-login:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 10rpx rgba(43, 160, 71, 0.3);
}

/* 7. 底部版权 */
.footer {
  margin-top: 60rpx;
  color: #b0bec5;
  font-size: 24rpx;
  text-align: center;
  animation: fadeIn 1s ease-out 0.5s backwards; /* 延迟更久 */
}

