/* pages/index/index.wxss */

/* 1. 页面整体：使用淡雅的医疗绿渐变，避免纯白枯燥 */
page {
  background: linear-gradient(180deg, #e8f5e9 0%, #f1f8e9 100%);
  min-height: 100vh;
}

.page-container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 2. 头部区域：使用品牌主色渐变，增强识别度 */
.nav-header {
  background: linear-gradient(135deg, #43a047, #2e7d32); /* 绿色渐变背景 */
  margin: -30rpx -30rpx 30rpx -30rpx; /* 抵消原来的 padding，撑满顶部 */
  padding: 40rpx 30rpx 50rpx 30rpx; /* 增加底部 padding */
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 0 0 60rpx 60rpx; /* 底部大圆弧，更加现代 */
  box-shadow: 0 10rpx 30rpx rgba(46, 125, 50, 0.3);
  color: white; /* 全局反白 */
  position: relative;
  z-index: 10;
}

.user-welcome {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.system-name {
  display: inline-block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-top: 5rpx;
}

.header-btns {
  display: flex;
  gap: 20rpx;
}

.link-btn {
  font-size: 26rpx;
  color: #2e7d32; /* 按钮内文字保持绿色 */
  background-color: white;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  font-weight: 600;
}

/* 患者信息条 - 置于最上方 */
.patient-info-bar {
  display: flex;
  justify-content: space-between; /* 两端对齐，左侧文字右侧按钮 */
  align-items: center;
  background-color: #e8f5e9; /* 浅绿背景条 */
  padding: 24rpx 30rpx;
  border-radius: 20rpx;
  color: #1b5e20;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.close-btn {
  background-color: #ef5350; /* 红色背景 */
  color: white;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 8rpx rgba(239, 83, 80, 0.3);
}

.close-btn:active {
  background-color: #d32f2f;
  transform: scale(0.95);
}

/* 3. 卡片通用样式：增强立体感 */
.card {
  background-color: white; /* 卡片保持白色，内容更清晰 */
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.08); /* 绿色系的柔和投影 */
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.1); /* 极淡的绿色边框 */
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.green-bar {
  width: 8rpx;
  height: 32rpx;
  background-color: #2e7d32;
  border-radius: 4rpx;
  margin-right: 15rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 4. 输入表单区域：恢复宽松的布局 */
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx; /* 增加间距 */
  background-color: #f9fbe7; /* 恢复原来的浅绿背景，区分度更高 */
  padding: 24rpx; /* 增加内边距，不那么紧凑 */
  border-radius: 12rpx;
}

.form-label {
  min-width: 200rpx;
  font-size: 30rpx;
  color: #555;
  font-weight: 500;
}

/* 确保 Picker 组件占满剩余空间 */
.form-picker {
  flex: 1;
  text-align: right;
  height: 1.6rem;
}

.form-input,
.picker-display {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
  height: 1.6rem;
  padding-right: 10rpx;
}

/* 按钮区域 */
.button-area {
  display: flex;
  gap: 30rpx;
  margin-top: 40rpx;
}

.btn-primary {
  flex: 2;
  background-color: #2e7d32;
  color: white;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.btn-secondary {
  flex: 1;
  background-color: #e8f5e9;
  color: #2e7d32;
  font-size: 30rpx;
  border-radius: 12rpx;
}

/* 5. 预测结果区域 */
.result-display-area {
  min-height: 240rpx;
  background-color: #f1f8e9; /* 极淡的绿色背景，区分预测报告区域 */
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 10rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.05);
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx dashed #eee;
}

.result-label {
  color: #666;
  font-size: 28rpx;
}

.result-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #2e7d32;
}

/* 专门针对恶性概率的样式：更突出 */
.result-item:first-child .result-value {
  font-size: 50rpx; /* 稍微显大一点点即可 */
  color: #c62828; /* 深红色，比鲜红沉稳 */
  font-weight: 700;
}

.result-item:first-child .result-label {
  font-weight: bold;
  color: #333;
}

/* AI 建议 */
.advice-box {
  margin-top: 30rpx;
  background-color: #e8f5e9;
  padding: 20rpx;
  border-radius: 10rpx;
  border-left: 6rpx solid #2e7d32;
}

.advice-title {
  display: block;
  font-size: 28rpx;
  color: #2e7d32;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.advice-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 保存按钮区域 */
.save-section {
  margin-top: 60rpx; /* 增加上间距，让它靠下 */
  padding-bottom: 20rpx;
}

.btn-save {
  background: white;
  color: #1976d2; /* 改为蓝色，与绿色区分 */
  border: 2rpx solid #1976d2;
  border-radius: 50rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(25, 118, 210, 0.1);
}

.btn-save:active {
  background-color: #e3f2fd;
}

/* -----------------------------
   6. 恢复的弹窗 (Modal) 样式 
   ----------------------------- */
.password-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5); /* 半透明遮罩 */
  z-index: 900;
}

.password-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  background-color: white;
  border-radius: 16rpx;
  z-index: 1000;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.password-modal-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.password-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.password-modal-close {
  color: #999;
  font-size: 40rpx;
  line-height: 1;
  padding: 10rpx;
}

.password-modal-body {
  padding: 40rpx 30rpx;
}

.password-input-item {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
}

.pwd-input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  padding-right: 60rpx; /* 留出眼睛图标位置 */
}

/* 弹窗内的眼睛图标 */
.password-modal .eye-toggle {
  position: absolute;
  right: 10rpx;
  top: 0;
  bottom: 0;
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* 复用 Login 页面的眼睛样式，如果你在一个全局wxss里定义过，这里可以省略，
   但为了保险，这里重新定义一套微缩版 */
.eye-shape {
  width: 32rpx;
  height: 20rpx;
  border: 3rpx solid #999;
  border-radius: 70% 15%;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.eye-pupil {
  width: 10rpx;
  height: 10rpx;
  background-color: #999;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.eye-slash {
  width: 36rpx;
  height: 3rpx;
  background-color: #999;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
  opacity: 1;
}

/* 睁眼状态 */
.eye-toggle.is-open .eye-slash {
  opacity: 0;
}
.eye-toggle.is-open .eye-shape {
  border-color: #2e7d32;
}
.eye-toggle.is-open .eye-pupil {
  background-color: #2e7d32;
}

.password-modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.password-modal-footer button {
  flex: 1;
  background-color: transparent;
  border-radius: 0;
  font-size: 32rpx;
  padding: 30rpx 0;
  line-height: 1.5;
}

.password-modal-footer button::after {
  border: none;
}

.btn-cancel {
  color: #666;
  border-right: 1rpx solid #eee !important;
}

.btn-confirm {
  color: #2e7d32;
  font-weight: bold;
}
